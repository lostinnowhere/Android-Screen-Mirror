#!/usr/bin/env bash
set -euo pipefail

install_all_cmd() {
    if command -v apt &>/dev/null; then
        prefix="sudo apt install"
        adb_pkg="adb"
    elif command -v pacman &>/dev/null; then
        prefix="sudo pacman -S"
        adb_pkg="android-tools"
    elif command -v dnf &>/dev/null; then
        prefix="sudo dnf install"
        adb_pkg="android-tools"
    elif command -v zypper &>/dev/null; then
        prefix="sudo zypper install"
        adb_pkg="android-tools"
    elif command -v apk &>/dev/null; then
        prefix="apk add"
        adb_pkg="android-tools"
    elif command -v xbps-install &>/dev/null; then
        prefix="sudo xbps-install"
        adb_pkg="android-tools"
    elif command -v brew &>/dev/null; then
        prefix="brew install"
        adb_pkg="android-platform-tools"
    else
        prefix=""
    fi

    local pkgs=()
    for cmd in "$@"; do
        case "$cmd" in
            adb) pkgs+=("$adb_pkg") ;;
            *)   pkgs+=("$cmd") ;;
        esac
    done

    if [[ -n "$prefix" ]]; then
        echo "$prefix ${pkgs[*]}"
    else
        echo "Please install: ${pkgs[*]}"
    fi
}

missing=()
for cmd in adb scrcpy; do
    if ! command -v "$cmd" &>/dev/null; then
        missing+=("$cmd")
    fi
done

if [[ ${#missing[@]} -gt 0 ]]; then
    printf "Missing dependencies: " >&2
    for i in "${!missing[@]}"; do
        if (( i > 0 )); then printf ", " >&2; fi
        printf "%s" "${missing[$i]}" >&2
    done
    install_cmd=$(install_all_cmd "${missing[@]}")
    printf "\n  Install: %s\n" "$install_cmd" >&2
    printf "Install now? (y/N): " >&2
    read -r answer
    if [[ "$answer" =~ ^[yY] ]]; then
        if [[ "$install_cmd" != sudo* && "$install_cmd" != apk* && "$install_cmd" != brew* ]]; then
            printf "Unsupported package manager. Please install manually.\n" >&2
            exit 1
        fi
        if bash -c "$install_cmd"; then
            # Re-check after install
            for cmd in "${missing[@]}"; do
                if ! command -v "$cmd" &>/dev/null; then
                    printf "Failed to install %s. Please install it manually.\n" "$cmd" >&2
                    exit 1
                fi
            done
        else
            printf "Installation failed.\n" >&2
            if command -v dnf &>/dev/null; then
                printf "  Fedora: scrcpy requires RPM Fusion.\n" >&2
                printf "  sudo dnf install https://mirrors.rpmfusion.org/free/fedora/rpmfusion-free-release-$(rpm -E %fedora).noarch.rpm\n" >&2
            elif command -v zypper &>/dev/null; then
                printf "  openSUSE: scrcpy requires Packman.\n" >&2
                if grep -qi "tumbleweed" /etc/os-release 2>/dev/null; then
                    os_version="openSUSE_Tumbleweed"
                elif grep -q "^VERSION_ID=" /etc/os-release 2>/dev/null; then
                    version=$(grep "^VERSION_ID=" /etc/os-release | cut -d= -f2 | tr -d '"')
                    os_version="openSUSE_Leap_$version"
                else
                    os_version="openSUSE_Tumbleweed"
                fi
                printf "  sudo zypper addrepo https://ftp.gwdg.de/pub/linux/misc/packman/suse/%s/ packman\n" "$os_version" >&2
            fi
            exit 1
        fi
    else
        exit 1
    fi
fi

wait_for_any_device() {
    echo "No Android device detected."
    echo "Make sure USB debugging is enabled on your device:"
    echo "  Settings → About phone → tap Build number 7 times"
    echo "  Settings → Developer options → USB debugging → ON"
    echo "Connect the device via USB and accept the authorization prompt."
    echo "Press Q to quit."
    echo ""
    local key
    while true; do
        read -t 1 -n 1 key || true
        if [[ "${key:-}" =~ [qQ] ]]; then
            echo ""
            exit 0
        fi
        devices=()
        while IFS= read -r line; do
            devices+=("$line")
        done < <(adb devices | awk 'NR>1 && NF {print $1}')
        if [[ ${#devices[@]} -gt 0 ]]; then
            return
        fi
        echo "No device found, searching ..."
    done
}

wait_for_device() {
    local serial="$1"
    local key
    while true; do
        read -t 1 -n 1 key || true
        if [[ "${key:-}" =~ [qQ] ]]; then
            echo ""
            exit 0
        fi
        if adb -s "$serial" get-state 2>/dev/null | grep -q -F "device"; then
            return
        fi
        echo "Waiting for device $serial ..."
    done
}

wait_for_any_device

echo "Connected devices:"
for i in "${!devices[@]}"; do
    name=$(adb -s "${devices[$i]}" shell getprop ro.product.model 2>/dev/null | tr -d '\r')
    echo "  $((i+1))) ${name:-Unknown}  (${devices[$i]})"
done

echo ""
echo "Keep device screen on?"
echo "  1) yes     2) no"
echo ""
echo "Device screen scaling:"
echo "  1) 0.25x     2) 0.5x      3) 0.75x     4) 1x (default)"
echo "  5) 1.25x     6) 1.5x      7) 1.75x     8) 2x"
echo ""
echo "  For a specific output resolution, enter the pixel value directly"
echo "  (e.g. 1280 for 720p, 1920 for 1080p)"

echo ""
printf "Enter choice (e.g. 121280 = device 1, screen off, 1280px): "
read -r input

input="${input:-11}"

dev_choice="${input:0:1}"
screen_choice="${input:1:1}"
screen_choice="${screen_choice:-1}"
rest="${input:2}"

if [[ ! "$dev_choice" =~ ^[0-9]+$ ]] || (( dev_choice < 1 || dev_choice > ${#devices[@]} )); then
    echo "Invalid device selection." >&2
    exit 1
fi
device="${devices[$((dev_choice-1))]}"

if [[ ! "$screen_choice" =~ ^[0-9]+$ ]] || (( screen_choice < 1 || screen_choice > 2 )); then
    echo "Invalid screen-off selection, using keep on." >&2
    screen_choice=1
fi

if [[ -z "$rest" ]]; then
    factor=1
    scale_choice=4
elif [[ "$rest" =~ ^[1-8]$ ]]; then
    scale_choice="$rest"
    case "$scale_choice" in
        1) factor=0.25 ;;
        2) factor=0.5 ;;
        3) factor=0.75 ;;
        4) factor=1 ;;
        5) factor=1.25 ;;
        6) factor=1.5 ;;
        7) factor=1.75 ;;
        8) factor=2 ;;
    esac
elif [[ "$rest" =~ ^[0-9]+$ ]] && (( rest > 0 )); then
    custom_max_size="$rest"
else
    echo "Invalid scale/resolution, using 1x." >&2
    factor=1
    scale_choice=4
fi

reconnecting=false
while true; do
    read -t 0.2 -n 1 key 2>/dev/null || true
    if [[ "${key:-}" =~ [qQ] ]]; then
        echo "" && exit 0
    fi

    wait_for_device "$device"

    resolution=$(adb -s "$device" shell wm size 2>/dev/null | sed -n 's/.*\([0-9]\{1,\}x[0-9]\{1,\}\).*/\1/p;q' || true)

    unset max_size
    if [[ -n "$resolution" ]]; then
        width="${resolution%%x*}"
        height="${resolution#*x}"
        if (( width > height )); then
            longest="$width"
        else
            longest="$height"
        fi
        if [[ -n "${custom_max_size:-}" ]]; then
            max_size="$custom_max_size"
        else
            max_size=$(awk "BEGIN {printf \"%.0f\", $longest * $factor}")
        fi
        [[ "$reconnecting" == false ]] && echo "  Resolution: ${width}x${height}, max-size: $max_size"
    elif [[ -n "${custom_max_size:-}" ]]; then
        max_size="$custom_max_size"
        [[ "$reconnecting" == false ]] && echo "  Using max-size: $max_size (resolution not detected)"
    elif [[ "${scale_choice:-4}" != 4 ]]; then
        echo "Warning: could not detect resolution, ignoring scale factor." >&2
    fi

    opts=""
    if [[ -n "${max_size:-}" ]]; then
        opts="--max-size $max_size"
    fi
    if [[ "$reconnecting" == true ]] || [[ "$screen_choice" == 2 ]]; then
        opts="$opts --turn-screen-off"
    fi

    scrcpy -s "$device" $opts &
    scrcpy_pid=$!

    while kill -0 $scrcpy_pid 2>/dev/null; do
        data=$(adb -s "$device" shell dumpsys battery 2>/dev/null || true)
        level=$(echo "$data" | awk -F': ' '/level:/ {print $2}')
        temp=$(echo "$data" | awk -F': ' '/temperature:/ {print $2}')
        temp_disp="?"
        [[ -n "$temp" ]] && temp_disp=$(awk "BEGIN {printf \"%.1fC\", $temp / 10}")
        line="  [$(date +%H:%M:%S)]  Battery: ${level:-?}%  Temp: $temp_disp"
        if [[ "$line" != "${last_line:-}" ]]; then
            echo "$line"
            last_line="$line"
        fi
        read -t 5 -n 1 key 2>/dev/null || true
        if [[ "${key:-}" =~ [qQ] ]]; then
            kill $scrcpy_pid 2>/dev/null; wait $scrcpy_pid 2>/dev/null
            echo "" && exit 0
        fi
    done
    wait $scrcpy_pid
    scrcpy_exit=$?
    echo ""

    if [[ $scrcpy_exit -eq 0 ]]; then
        exit 0
    fi

    reconnecting=true

    # Check if device is still reachable — if yes, scrcpy failed for a
    # non-connection reason (codec, config, etc.) and we should give up.
    if adb -s "$device" get-state 2>/dev/null | grep -q -F "device"; then
        echo "scrcpy failed unexpectedly, exiting." >&2
        exit 1
    fi

    echo "Connection lost. Retrying in 2 seconds... (press Q to quit)"
    read -t 2 -n 1 key 2>/dev/null || true
    [[ "${key:-}" =~ [qQ] ]] && echo "" && exit 0
done
